# IOTA NIF — Environment Variables
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will NOT be committed.
#
# To export your Ed25519 private key from the IOTA CLI:
#   iota keytool export --key-identity $(iota client active-address)

# (Required) Ed25519 private key in Bech32 format (iotaprivkey1...)
# Also accepts Base64-encoded keys (32 or 33 bytes).
IOTA_SECRET_KEY=iotaprivkey1qz...

# (Optional) IOTA node URL. Defaults to http://127.0.0.1:9000 if not set.
# Testnet: https://api.testnet.iota.cafe
# Mainnet: https://api.mainnet.iota.cafe
IOTA_NODE_URL=https://api.testnet.iota.cafe

# (Optional) Identity package ObjectID on the IOTA Rebased ledger.
# Pass an empty string or omit to auto-discover on official networks.
IOTA_IDENTITY_PKG_ID=

# (Optional) Notarization package ObjectID on the IOTA Rebased ledger.
# Pass an empty string or omit to auto-discover on official networks.
IOTA_NOTARIZE_PKG_ID=
